{
  "version": 2,
  "builds": [
    {
      "src": "src/server.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/src/server.js"
    }
  ],
  "crons": [
    {
      "path": "/api/auto-toggle-vendors",
      "schedule": "* * * * *"
    }
  ]
}